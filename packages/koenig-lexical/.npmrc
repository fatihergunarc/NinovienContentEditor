# The publish workflow installs this package standalone with
# `npm install --no-workspaces --legacy-peer-deps`. Subsequent npm commands
# (notably `npm version`, which reconciles the dependency tree) must use the
# same peer-deps leniency, otherwise they fail with ERESOLVE on the
# pre-existing vitest/@vitest peer mismatch. Keep this here so every npm
# invocation in this package honours it.
legacy-peer-deps=true
